NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Set this before deployment. It protects /admin and admin API actions.
ADMIN_SHARED_SECRET=change-this-long-random-password

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=grok-4.20-0309-non-reasoning

# X API bearer token for #ConferenceHype and @conferencehype monitoring.
X_BEARER_TOKEN=

# Kokoro TTS — local Python library mode (no server needed).
# Requires: pip install kokoro numpy soundfile
# Voice IDs are the internal Kokoro Python names from scripts/generate-kokoro-dj-voice.py.
#
# KOKORO_PYTHON_CMD — Python executable used to run the Kokoro script.
#   Windows (Python Launcher): py -3.12
#   Linux / macOS / GitHub Actions: python3
#   Virtual environment: /path/to/venv/bin/python
KOKORO_PYTHON_CMD=py -3.12
#
# Optional: set VOICE_API_URL to a hosted Kokoro FastAPI endpoint to use HTTP mode instead.
VOICE_API_URL=

# 17 distinct Kokoro voices, one per persona (no two personas share a voice).
# Values are the Kokoro Python voice IDs — see VOICE_MIX in scripts/generate-kokoro-dj-voice.py
# for the supported list and add a VOICE_MIX/VOICE_TITLES entry there before using a new ID.
VOICE_ECHO_SAGE=am_fenrir
VOICE_NOVA_QUINN=af_heart
VOICE_KAI_LENNOX=am_michael
VOICE_DIEGO_VALE=am_echo
VOICE_AMARA_SOL=af_bella
VOICE_MILES_CARTER=am_adam
VOICE_SOFIA_REYES=af_sarah
VOICE_BENJI_CROSS=bm_lewis
VOICE_ELENA_PARK=af_jessica
VOICE_GRANT_IVEY=am_eric
VOICE_TALIA_STONE=af_nova
VOICE_SAGE_HARLAN=am_liam
VOICE_LUNA_VALE=bf_emma
VOICE_ORION_REED=am_onyx
VOICE_RILEY_KNOX=bm_daniel
VOICE_AETHER_VALE=am_puck
VOICE_VESPER_QUILL=af_kore

NEXT_PUBLIC_YOUTUBE_VIDEO_ID=
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=

# GitHub PAT with repo + workflow scopes. Used by the admin Start Stream button
# to dispatch the youtube-stream.yml workflow via the GitHub Actions API.
# Set this in Vercel env vars (not just locally).
GITHUB_DISPATCH_TOKEN=
# Recommended for crowded conference Wi-Fi: lightweight audio-only stream.
NEXT_PUBLIC_AUDIO_STREAM_URL=
# Low-bitrate HLS fallback, ideally with adaptive variants.
NEXT_PUBLIC_HLS_URL=
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2
YOUTUBE_STREAM_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=unlisted

VOICE_AUDIO_PATH=public/placeholders/sample-voice.wav
MUSIC_AUDIO_PATH=public/music/light-jazz-techno.mp3
RENDER_OUTPUT_PATH=public/rendered/sample-segment.m4a
STREAM_INPUT_PATH=public/rendered/fallback-loop.mp4
